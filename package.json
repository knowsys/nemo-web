{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run buildNoTsc",
    "buildNoTsc": "vite build && npm run generateLicenseFile",
    "lint": "prettier --write . && eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "generateLicenseFile": "generate-license-file --ci --input package.json --output dist/3rd-party-licenses.txt"
  },
  "dependencies": {
    "@codingame/esbuild-import-meta-url-plugin": "^1.0.3",
    "@codingame/monaco-vscode-api": "^29.1.1",
    "@codingame/monaco-vscode-extension-api": "^29.1.1",
    "@codingame/monaco-vscode-extensions-service-override": "^29.1.1",
    "@codingame/monaco-vscode-languages-service-override": "^29.1.1",
    "@codingame/monaco-vscode-rollup-vsix-plugin": "^29.1.1",
    "@codingame/monaco-vscode-textmate-service-override": "^29.1.1",
    "@codingame/monaco-vscode-theme-defaults-default-extension": "^29.1.1",
    "@codingame/monaco-vscode-theme-service-override": "^29.1.1",
    "@reduxjs/toolkit": "^1.9.7",
    "@types/wicg-file-system-access": "^2023.10.2",
    "bootstrap": "^5.3.2",
    "bootstrap-icons": "^1.11.1",
    "i18next": "^23.6.0",
    "i18next-browser-languagedetector": "^7.1.0",
    "immutable": "^4.3.4",
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@^29.1.1",
    "react": "^18.2.0",
    "react-bootstrap": "^2.9.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.3.1",
    "react-redux": "^8.1.3",
    "vite-plugin-top-level-await": "^1.6.0"
  },
  "devDependencies": {
    "@rollup/pluginutils": "^5.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
